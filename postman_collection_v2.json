{
  "info": {
    "name": "OTT Backend V2 API Collection",
    "description": "Complete Postman collection for OTT Backend Version 2 APIs (Parallel Search, Provider Details, Proxied Streaming extraction)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:6000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "System",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Health check endpoint for the backend server."
          }
        }
      ]
    },
    {
      "name": "V2 APIs",
      "item": [
        {
          "name": "Parallel Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/search?q=Superman Returns",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Superman Returns",
                  "description": "The search query query term to look up across all providers (Net11, Net52, TMDB)."
                }
              ]
            },
            "description": "Perform a parallel, fast hybrid search returning merged results from Net11, Net52, and TMDB search results."
          }
        },
        {
          "name": "Get Details by Provider (Net11)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/details/net11/70041963?title=Superman Returns&year=2006",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "details",
                "net11",
                "70041963"
              ],
              "query": [
                {
                  "key": "title",
                  "value": "Superman Returns",
                  "description": "(Optional) Fallback title if search provider lacks details"
                },
                {
                  "key": "year",
                  "value": "2006",
                  "description": "(Optional) Fallback release year"
                }
              ]
            },
            "description": "Fetches metadata details from specific provider. Supported providers: net11, net52."
          }
        },
        {
          "name": "Get Details by Provider (Net52)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/details/net52/70041963?title=Superman Returns&year=2006",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "details",
                "net52",
                "70041963"
              ],
              "query": [
                {
                  "key": "title",
                  "value": "Superman Returns",
                  "description": "(Optional) Fallback title"
                },
                {
                  "key": "year",
                  "value": "2006",
                  "description": "(Optional) Fallback release year"
                }
              ]
            },
            "description": "Fetches metadata details from Net52 provider."
          }
        },
        {
          "name": "Extract Streams by Provider (Net11)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/stream/net11/70041963?debug=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "stream",
                "net11",
                "70041963"
              ],
              "query": [
                {
                  "key": "debug",
                  "value": "true",
                  "description": "Get raw scraper telemetry from provider (active only in non-production)"
                }
              ]
            },
            "description": "Resolves playable streams and SRT/VTT subtitles, automatically wrapping them in proxied URLs to prevent browser CORS and cookie restrictions."
          }
        },
        {
          "name": "Extract Streams by Provider (Net52)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/stream/net52/70041963?debug=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "stream",
                "net52",
                "70041963"
              ],
              "query": [
                {
                  "key": "debug",
                  "value": "true",
                  "description": "Get raw scraper telemetry from provider"
                }
              ]
            },
            "description": "Resolves playable streams and subtitles from Net52, proxied."
          }
        },
        {
          "name": "Stream Proxy",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v2/stream/proxy?provider=net11&u=https%3A%2F%2Fnet11.cc%2Fhls%2F70041963.m3u8",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "stream",
                "proxy"
              ],
              "query": [
                {
                  "key": "provider",
                  "value": "net11",
                  "description": "Target provider for domain resolving (net11 or net52)"
                },
                {
                  "key": "u",
                  "value": "https://net11.cc/hls/70041963.m3u8",
                  "description": "Encoded source URL (HLS playlist .m3u8, segment .ts, or subtitle .vtt/.srt)"
                }
              ]
            },
            "description": "Proxies streaming segments, playlists, and subtitles through backend with custom headers, User-Agent, cookie preservation, and referers to prevent blocked plays."
          }
        }
      ]
    }
  ]
}
